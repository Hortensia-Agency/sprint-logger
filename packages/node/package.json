{
  "name": "@sprint-logger/node",
  "version": "0.1.1",
  "description": "Sprint Signals error logger for Node services. init() once at boot, captureException() around boundaries. Pseudonymous, PII-safe.",
  "keywords": [
    "error-tracking",
    "error-logging",
    "sprint",
    "signals",
    "node",
    "observability"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Hortensia-Agency/sprint-logger.git",
    "directory": "packages/node"
  },
  "homepage": "https://github.com/Hortensia-Agency/sprint-logger/tree/main/packages/node#readme",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "sideEffects": false,
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "verify": "tsup && publint --strict"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "publint": "^0.2.12",
    "tsup": "^8.3.5",
    "typescript": "^5.6.0"
  }
}
